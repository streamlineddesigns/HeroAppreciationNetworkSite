{% extends "app.twig" %}

{% block pageStyles %}
    <link rel="stylesheet" href="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.css">
    
{% endblock %}

{% block title %}Icon Types{% endblock %}

{% block content %}

  {% if hasMessages() %}
    {% if successMessage() %}
        <script>swal("Success!", "{{successMessage()}}", "success");</script>
    {% elseif errorMessage() %}
        <script>swal("Error!", "{{errorMessage()}}", "error");</script>
    {% endif %}
  {% endif %}

  <div class="container my-5">

        <a href="{{url('/superuser/icontypes/create')}}" class="btn btn-success mb-5 float-right"><i class="bi bi-plus"></i> New</a>

        {% if icontypes %}
            <table class="table table-striped table-dark table-bordered table-responsive" data-toggle="table" data-pagination="true" data-search="true">
                <thead>
                    <tr>
                        <th class="mobile-hidden" data-sortable="true">ID</th>
                        <th data-sortable="true">Type</th>
                        <th class="actions"></th>
                    </tr>
                </thead>
                <tbody>
                {% for icontype in icontypes %}

                    <tr>
                        <td class="mobile-hidden">
                            {{ icontype.id }}
                        </td>
                        <td class="primary-mobile-td">
                            {{ icontype.type }}
                        </td>
                        <td class="mobile-td text-center">
                            <a href="/superuser/icontypes/{{ icontype.id }}/edit" class="btn btn-primary"><i class="bi bi-pencil"></i><span class="mobile-hidden"> Edit</span></a>
                            <a href="/superuser/icontypes/{{ icontype.id }}" class="btn btn-secondary"><i class="bi bi-eye"></i><span class="mobile-hidden"> View</span></a>
                            <a href="javascript:FunApp.deleteResource({{ icontype.id }}, 'icon type', 'delete-form-{{ icontype.id }}')" class="btn btn-danger"><i class="bi bi-trash"></i><span class="mobile-hidden"> Delete</span></a>
                            <form method="post" action="/superuser/icontypes/{{ icontype.id }}/delete" id="delete-form-{{ icontype.id }}"></form>
                        </td>
                    </tr>

                {% endfor %}
                </tbody>
            </table>
        {% else %}
            No icon types found.
        {% endif %}
    </div>

{% endblock %}

{% block pageScripts %}
    <script src="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.js"></script>
    <script src="{{url('/assets/js/FunApp.js')}}"></script>
{% endblock %}