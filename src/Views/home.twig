{% extends "app.twig" %}

{% block pageStyles %}
    <style>
    .profile-img-custom {
		height: 100px;
		width: 100px;
		border-radius: 50%;
		background-size: contain;
		box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
		background-repeat: no-repeat;
		background-position: center;
		background-color: #222222;
		margin: 0 auto;
	}
    </style>
{% endblock %}


{% block title %}Home{% endblock %}

{% block content %}

	{% if hasMessages() %}
		{% if successMessage() %}
			<script>swal("Success!", "{{successMessage()}}", "success");</script>
		{% elseif errorMessage() %}
			<script>swal("Error!", "{{errorMessage()}}", "error");</script>
		{% endif %}
  	{% endif %}

    <!--====== Hero Area Start ======-->
	<section class="hero-area-one">
		<div class="hero-text">
			<div class="container">
				<div class="row justify-content-center">
					<div class="col-xl-10">
						<span class="tagline wow fadeInUp" data-wow-delay="0.3s">Donation wars</span>
						<h1 class="title wow fadeInUp" data-wow-delay="0.4s">Help your community get to the highest ranks</h1>
						<a href="{{url('/organizations')}}" class="btn main-btn wow fadeInUp" data-wow-delay="0.5s">
							Explore Projects <i class="far fa-arrow-right"></i>
						</a>
					</div>
				</div>
			</div>
			<div class="hero-shapes">
				<div class="hero-line-one">
					<img src="{{url('/assets/img/hero/hero-line.png')}}" alt="Line">
				</div>
				<div class="hero-line-two">
					<img src="{{url('/assets/img/hero/hero-line-2.png')}}" alt="Line">
				</div>
				<div class="dot-one"></div>
				<div class="dot-two"></div>
			</div>
		</div>
		<!--<div class="hero-images">
			<div class="hero-img image-small fancy-bottom wow fadeInLeft" data-wow-delay="0.6s">
				<img src="{{url('/assets/img/hero/hero-one-small.jpg')}}" alt="Image">
			</div>
			<div class="hero-img main-img wow fadeInUp" data-wow-delay="0.5s">
				<img src="{{url('/assets/img/hero/hero-one-big.jpg')}}" alt="Image">
			</div>
			<div class="hero-img image-small fancy-top wow fadeInRight" data-wow-delay="0.7s">
				<img src="{{url('/assets/img/hero/hero-one-small-2.jpg')}}" alt="Image">
			</div>
		</div>-->
	</section>
	<!--====== Hero Area End ======-->

	<!--====== Counter Area Start ======-->
	<section class="counter-section-one mt-negative">
		<div class="container primary-bg">
			<div class="row counter-boxes justify-content-xl-between justify-content-center">
				<div class="col-xl-auto col-lg-5 col-md-5 col-sm-6">
					<div class="counter-box mb-40 icon-left">
						<div class="icon white-color">
							<i class="flaticon-crowdfunding"></i>
						</div>
						<div class="content white-color">
							<div class="count-wrap">
								$<span class="count">{{ donation_statistics['average_donation'] }}</span>
								<span class="suffix">+</span>
							</div>
							<h6 class="title">Average Donation</h6>
						</div>
					</div>
				</div>
				<div class="col-xl-auto col-lg-5 col-md-5 col-sm-6">
					<div class="counter-box mb-40 icon-left">
						<div class="icon white-color">
							<i class="flaticon-crowdfunding"></i>
						</div>
						<div class="content white-color">
							<div class="count-wrap">
								$<span class="count">{{ donation_statistics['total_donations'] }}</span>
								<span class="suffix">+</span>
							</div>
							<h6 class="title">$ Donations Made</h6>
						</div>
					</div>
				</div>
				<div class="col-xl-auto col-lg-5 col-md-5 col-sm-6">
					<div class="counter-box mb-40 icon-left">
						<div class="icon white-color">
							<i class="flaticon-crowdfunding"></i>
						</div>
						<div class="content white-color">
							<div class="count-wrap">
								<span class="count">{{ donation_statistics['total_organizations'] }}</span>
								<span class="suffix">+</span>
							</div>
							<h6 class="title">Organizations</h6>
						</div>
					</div>
				</div>
				<div class="col-xl-auto col-lg-5 col-md-5 col-sm-6">
					<div class="counter-box mb-40 icon-left">
						<div class="icon white-color">
							<i class="flaticon-crowdfunding"></i>
						</div>
						<div class="content white-color">
							<div class="count-wrap">
								<span class="count">{{ donation_statistics['donations_count'] }}</span>
								<span class="suffix">+</span>
							</div>
							<h6 class="title"># Donations Made</h6>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
	<!--====== Counter Area End ======-->

	<!--====== Project Section Start ======-->
	<section class="project-section project-section-extra-gap primary-bg my-5">
		<div class="container-fluid fluid-extra-padding">
			<div class="common-heading text-center color-version-white mb-60">
				<span class="tagline">
					<i class="fas fa-plus"></i> Popular Projects
					<span class="heading-shadow-text">Our Projects</span>
				</span>
				<h2 class="title">Explore Our Projects</h2>
			</div>
			<div class="row project-slider-one project-items project-style-one no-shadow">
				{% for organization in all_organizations %}
                        <div class="col-lg-4 p-3">
                            <div class="card p-2 rounder shadow">
                                <div class="thumb card-img-top organization_featured_img" style="background-image: url(/assets/img/uploads/organizations/{{organization.id}}/{{organization.featured_img_url}});"></div>
                                <div class="card-body">
                                    <h5 class="card-title text-center">
                                        <a href="/organizations/{{ organization.id }}" class="brand-color no-decoration">{{ organization.name }}</a>
                                    </h5>
                                    <p class="card-text">
                                        <p style="min-height: 150px;">{{ shorten(organization.about_us_text) }}</p>
                                    </p>
                                </div>
                                
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item">
                                        <p class="text-center social-medias brand-color">
                                            <i class="fab fa-2x fa-facebook"></i>
                                            <i class="fab fa-2x fa-instagram"></i>
                                            <i class="fab fa-2x fa-twitter"></i>
                                            <i class="fab fa-2x fa-linkedin"></i>
                                            <i class="fab fa-2x fa-google"></i>
                                        </p>
                                    </li>
                                </ul>
                                <ul class="list-group list-group-flush text-center">
                                    <li class="list-group-item">
                                        <strong class="brand-color">Raised ${{organization.donations_total}}</strong>
                                    </li>
                                </ul>

                                <div class="card-body aligned">
                                    <a href="/organizations/{{ organization.id }}/donate" class="main-btn nav-btn d-none d-sm-inline-block shadow">Donate</a>
                                </div>
                            </div>
                        </div>
                {% endfor %}
			</div>
		</div>
	</section>
	<!--====== Project Section End ======-->


    <!--====== Categories Section Start ======-->
	<section class="popular-categories section-gap">
		<div class="container">
			<div class="categories-header">
				<div class="row align-items-center justify-content-between">
					<div class="col-auto">
						<div class="common-heading mb-30">
							<span class="tagline">
								<i class="fas fa-plus"></i> Rank up
								<span class="heading-shadow-text">Highest Ranked</span>
							</span>
							<i class="fas fa-crown fa-2x"></i><h2 class="title d-inline"> Popular Organizations </h2><i class="fas fa-crown fa-2x"></i>
						</div>
					</div>
					<div class="col-auto">
						<a href="{{url('/organizations')}}" class="main-btn mb-30">View More <i class="far fa-angle-right"></i></a>
					</div>
				</div>
			</div>
			<div class="row justify-content-center fancy-icon-boxes">
				{% for organization in topThree %}
                        <div class="col-lg-4 p-3" style="z-index:10;">
                            <div class="card p-2 rounder shadow">
                                <div class="thumb card-img-top organization_featured_img" style="background-image: url(/assets/img/uploads/organizations/{{organization.id}}/{{organization.featured_img_url}});"></div>
                                <div class="card-body">
                                    <h5 class="card-title text-center">
                                        <a href="/organizations/{{ organization.id }}" class="brand-color no-decoration">{{ organization.name }}</a>
                                    </h5>
                                    <p class="card-text">
                                        <p style="min-height: 150px;">{{ shorten(organization.about_us_text) }}</p>
                                    </p>
                                </div>
                                
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item">
                                        <p class="text-center social-medias brand-color">
                                            <i class="fab fa-2x fa-facebook"></i>
                                            <i class="fab fa-2x fa-instagram"></i>
                                            <i class="fab fa-2x fa-twitter"></i>
                                            <i class="fab fa-2x fa-linkedin"></i>
                                            <i class="fab fa-2x fa-google"></i>
                                        </p>
                                    </li>
                                </ul>
                                <ul class="list-group list-group-flush text-center">
                                    <li class="list-group-item">
                                        <strong class="brand-color">Raised ${{organization.donations_total}}</strong>
                                    </li>
                                </ul>

                                <div class="card-body aligned">
                                    <a href="/organizations/{{ organization.id }}/donate" class="main-btn nav-btn d-none d-sm-inline-block shadow">Donate</a>
                                </div>
                            </div>
                        </div>
                {% endfor %}
			</div>
		</div>
	</section>
	<!--====== Categories Section End ======-->

	<!--====== About Section Start ======-->
	<section class="about-section-two mb-5">
		<div class="about-text-area">
			<div class="container">
				<div class="row align-items-center">
					<div class="col-lg-6 wow fadeInUp aligned p-5">
						<div class="about-curved-img p-5 ">
							<img src="assets/img/about/man-with-laptop.png" class="rounder shadow" style="max-height: 550px;" alt="Image">
						</div>
					</div>
					<div class="col-lg-6 wow fadeInUp aligned p-5">
						<div class="about-text ">
							<div class="common-heading mb-30">
								<span class="tagline">
									<i class="fas fa-plus"></i> What we are
									<span class="heading-shadow-text">What we are</span>
								</span>
								<h2 class="title">Charity made fun.</h2>
							</div>
							<p>
								Subscribe to organizations to keep up to date on what they are doing. Donate to them anytime within seconds.
								See who your followers subscribe to as well & who & where they make donations to.
								Build Karma and help improve our communities!
							</p>
							<ul class="check-list mt-30">
								<li>
									<h5 class="title">Find and follow organizations you like</h5>
									<p>Check out any organization and see what they are doing. You can see their reviews, recent posts, & what donations they've recieved as well as what they've spent the donations on. Throughout this process, you'll become informed on the difference this organization is making in the world. Afterwards, its our hope you'll choose to become apart of that difference & donate.</p>
								</li>
								<li>
									<h5 class="title">See who your friends are donating to</h5>
									<p>Follow your friends and keep up to date on things. When you see them donate to an organization, you'll have a chance to donate to that same one as well. This will build karma faster for you both!</p>
								</li>
								<li>
									<h5 class="title">Donate to compete & help!</h5>
									<p>Your donations can increase an organizations ranking, and increase its exposure, therefore helping it even further. This benefits everyone!</p>
								</li>
							</ul>
							<a href="{{ url('/about') }}" class="main-btn btn-dark mt-40">Learn More <i class="far fa-arrow-right"></i></a>
						</div>
						
					</div>
					
				</div>
			</div>
		</div>
	</section>
	<!--====== About Section End ======-->


	<!--====== Team section Start ======-->
	<section class="team-slider-area">
		<div class="container mb-20">
			<div class="row align-items-center justify-content-between">
				<div class="col-lg-6">
					<div class="common-heading mb-40">
						<span class="tagline">
							<i class="fas fa-plus"></i> Donors
							<span class="heading-shadow-text">Donors</span>
						</span>
						<h2 class="title">Top Donations</h2>
					</div>
				</div>
			</div>

		</div>
		<div class="container-fluid fluid-extra-padding">
			<div class="row team-members team-slider primary-bg">

				{% for donation in donations %}
				<li class="list-inline-item p-2 hidden donation_list_item text-center aligned shadow m-3 left-leaf custom-test border-branded">
					{% if donation.profile_img_url %} 
						{% if donation.is_invisible == 0 %}
							<div class="profile-img-custom" style="background-image: url('/assets/img/default_profile_img.png');"></div>
						{% else %}
							<div class="profile-img-custom" style="background-image: url(/assets/img/uploads/users/{{ donation.user_id }}/{{ donation.profile_img_url }});"></div>
						{% endif %}
					{% else %}
						<div class="profile-img-custom" style="background-image: url('/assets/img/default_profile_img.png');"></div>
					{% endif %}
					<span class="bolder">
					{% if donation.is_invisible == 0 %}
						Private
					{% else %}
						<h5 class="brand-color"><a class="brand-color" href="{{ url('/user/profile/v/') }}{{donation.user_id }}">{{donation.fname}} {{donation.lname}}</a></h5>
						
					{% endif %}
					
					
					</span>


					<h5 class="bolder brand-color">${{donation.amount}}</h5>
					<h5 class="bolder text-white"><a class="brand-color" href="/organizations/{{donation.org_id }}">{{donation.org_name}}</a></h5>
				</li>
				{% endfor %}
				

			</div>
		</div>
	</section>
	<!--====== Team section End ======-->


	<!--====== Emergency Project & CTA Start ======-->
	<section class="emergency-project-with-cta">
		<div class="container">
			<!-- Call to Action -->
			<div class="cta-box cta-double-content" style="background-image: url({{url('/assets/img/cta/01.jpg')}});">
				<div class="row justify-content-center">
					<div class="col-xl-4 col-lg-5 col-md-9">
						<div class="content">
							<h2 class="cta-title">Register Organization</h2>
							<p class="white-text text-white">Are you an organization and you want to sign up?</p>
							<a href="{{url('/contact')}}" class="main-btn">Sign Up! <i class="far fa-arrow-right"></i></a>
						</div>
					</div>
					<div class="col-xl-2 col-lg-1 cta-double-content-gap"></div>
					<div class="col-xl-4 col-lg-5 col-md-9">
						<div class="content">
							<h2 class="cta-title">Make a donation today</h2>
							<p class="white-text text-white">Do you want to donate to you favorite organization?</p>
							<a href="{{url('/organizations')}}" class="main-btn">Donate Now! <i class="far fa-arrow-right"></i></a>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="emergency-project-slider">
			
		</div>
	</section>
	<!--====== Emergency Project & CTA End ======-->

{% endblock %}