{% extends "app.twig" %}

{% block pageStyles %}
    <link rel="stylesheet" href="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.css">
    
{% endblock %}

{% block title %}Tokens{% endblock %}

{% block content %}

  {% if hasMessages() %}
    {% if successMessage() %}
        <script>swal("Success!", "{{successMessage()}}", "success");</script>
    {% elseif errorMessage() %}
        <script>swal("Error!", "{{errorMessage()}}", "error");</script>
    {% endif %}
  {% endif %}

  <div class="container my-5">

        <a href="javascript:FunApp.backButtonClick()" class="btn btn-success mb-5"><i class="bi bi-chevron-left"></i> Back</a>

        <form method="post" action="{{url('/superuser/organizations/tokens')}}">
            <div class="card bg-dark text-white text-center">
                <div class="card-header">
                    <h2 class="text-white">Create Token</h2>
                    <hr>
                </div>
                <div class="card-body">
                    <div class="card-text">
                        <label for="email" class="form-label float-left text-white">Email</label>
                        <input type="email" class="form-control" name="email" placeholder="Enter Email" required>
                        <div class="form-group mt-5 text-left">
                            <label for="org_name" class="form-label float-left text-white">Organization Name</label>
                            <input type="text" class="form-control" id="org_name" name="org_name" placeholder="Enter Organization Name" required>
                        </div>
                        <div class="form-group mt-5 text-left">
                            <div>
                                <i class="" id="section_icon"></i>
                            </div>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary float-right mt-5"><i class="bi bi-plus"></i> Create</button>
                </div>
                <div class="card-footer">

                </div>
            </div>
        </form>
    </div>

{% endblock %}

{% block pageScripts %}
    <script src="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.js"></script>
    <script src="{{url('/assets/js/FunApp.js')}}"></script>
    <script>
        $("#class_name").change(function() {
            $("#section_icon").removeClass();
            $("#section_icon").addClass($(this).val());
            $("#section_icon").addClass("fa-3x");
        });
    </script>
{% endblock %}