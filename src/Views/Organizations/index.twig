{% extends "app.twig" %}

{% block pageStyles %}
    <link rel="stylesheet" href="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.css">
    
{% endblock %}

{% block title %}Organizations{% endblock %}

{% block content %}

  {% if hasMessages() %}
    {% if successMessage() %}
        <script>swal("Success!", "{{successMessage()}}", "success");</script>
    {% elseif errorMessage() %}
        <script>swal("Error!", "{{errorMessage()}}", "error");</script>
    {% endif %}
  {% endif %}

    <!--====== Page Title Start ======-->
	<section class="page-title-area page-title-area-custom">
		<div class="container">
			<div class="row align-items-center justify-content-between">
				<div class="col-lg-12 text-center">
					<h1 class="page-title text-white">Organizations</h1>
				</div>
			</div>
		</div>
	</section>
	<!--====== Page Title End ======-->

  <div class="container my-5">
    
        {% if organizations %}

            <!--====== Project Area Start ======-->
            <section class="project-section section-gap-extra-bottom primary-soft-bg p-5">
                <div class="container">
                    <div class="row project-items project-style-three justify-content-center">

                        {% for organization in organizations %}
                        <div class="col-lg-4">
                            <div class="card p-3">
                                <div class="thumb card-img-top organization_featured_img" style="background-image: url(/assets/img/uploads/organizations/{{organization.id}}/{{organization.featured_img_url}});"></div>
                                <div class="card-body">
                                    <h5 class="card-title text-center">
                                        <a href="/organizations/{{ organization.id }}" class="brand-color no-decoration">{{ organization.name }}</a>
                                    </h5>
                                    <p class="card-text">
                                        <p>{{ shorten(organization.about_us_text) }}</p>
                                    </p>
                                </div>
                                
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item">
                                        <p class="text-center social-medias brand-color">
                                            <i class="fab fa-2x fa-facebook"></i>
                                            <i class="fab fa-2x fa-instagram"></i>
                                            <i class="fab fa-2x fa-twitter"></i>
                                            <i class="fab fa-2x fa-linkedin"></i>
                                            <i class="fab fa-2x fa-google"></i>
                                        </p>
                                    </li>
                                </ul>
                                <ul class="list-group list-group-flush text-center">
                                    <li class="list-group-item">
                                        <strong class="brand-color">Raised $0</strong>
                                    </li>
                                </ul>

                                <div class="card-body aligned">
                                    <a href="/organizations/{{ organization.id }}/donate" class="main-btn nav-btn d-none d-sm-inline-block shadow">Donate</a>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                        <!--<div class="col-12">
                            <div class="view-more-btn text-center mt-40">
                                <a href="project-details.html" class="main-btn bordered-btn">View More Project <i class="far fa-arrow-right"></i></a>
                            </div>
                        </div>-->
                    </div>
                </div>
            </section>
            <!--====== Project Area End ======-->
        {% else %}
            No organization found.
        {% endif %}
    </div>

{% endblock %}

{% block pageScripts %}
    <script src="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.js"></script>
    <script src="{{url('/assets/js/FunApp.js')}}"></script>
{% endblock %}