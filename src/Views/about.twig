			<div class="container">
				<div class="row align-items-end justify-content-xl-start">
					<div class="col-lg-6 wow fadeInUp aligned p-5">
						<div class="about-curved-img p-5 ">
							<img src="assets/img/about/man-with-laptop.png" class="rounder shadow" style="max-height: 550px;" alt="Image">
						</div>
					</div>
					<div class="col-lg-6 wow fadeInUp aligned p-5">
