{% extends "app.twig" %}

{% block pageStyles %}
    <link rel="stylesheet" href="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.css">
    
{% endblock %}

{% block title %}Donations{% endblock %}

{% block content %}

  {% if hasMessages() %}
    {% if successMessage() %}
        <script>swal("Success!", "{{successMessage()}}", "success");</script>
    {% elseif errorMessage() %}
        <script>swal("Error!", "{{errorMessage()}}", "error");</script>
    {% endif %}
  {% endif %}

  <div class="container my-5">

        <!--<a href="{{url('/superuser/donations/create')}}" class="btn btn-success mb-5 float-right"><i class="bi bi-plus"></i> New</a>-->

        {% if donations %}
            <table class="table table-striped table-dark table-bordered table-responsive" data-toggle="table" data-pagination="true" data-search="true">
                <thead>
                    <tr>
                        <th class="mobile-hidden" data-sortable="true">ID</th>
                        <th data-sortable="true">Amount</th>
                        <th data-sortable="true">From</th>
                        <th data-sortable="true">To</th>
                        <th data-sortable="true">Date</th>
                        <!--<th class="actions"></th>-->
                    </tr>
                </thead>
                <tbody>
                {% for donation in donations %}

                    <tr>
                        <td class="mobile-hidden">
                            {{ donation.id }}
                        </td>
                        <td class="primary-mobile-td">
                            ${{ donation.amount }}
                        </td>
                        <td class="primary-mobile-td">
                            <a href="{{url('/user/profile/v/')}}{{donation.user_id}}">{{ donation.fname }} {{ donation.lname }}</a>
                        </td>
                        <td class="primary-mobile-td">
                            
                            <a href="{{url('/organizations/')}}{{donation.org_id}}">{{ donation.org_name }}</a>
                        </td>
                        <td class="primary-mobile-td">
                            {{ donation.created_at|format_datetime() }}
                        </td>
                        <!--<td class="mobile-td text-center">
                            <a href="/superuser/donations/{{ donation.id }}/edit" class="btn btn-primary"><i class="bi bi-pencil"></i><span class="mobile-hidden"> Edit</span></a>
                            <a href="/superuser/donations/{{ donation.id }}" class="btn btn-secondary"><i class="bi bi-eye"></i><span class="mobile-hidden"> View</span></a>
                            <!--<a href="javascript:FunApp.deleteResource({{ donation.id }}, 'icon type', 'delete-form-{{ donation.id }}')" class="btn btn-danger"><i class="bi bi-trash"></i><span class="mobile-hidden"> Delete</span></a>-->
                            <!--<form method="post" action="/superuser/donations/{{ donation.id }}/delete" id="delete-form-{{ donation.id }}"></form>
                        </td>-->
                    </tr>

                {% endfor %}
                </tbody>
            </table>
        {% else %}
            No icon types found.
        {% endif %}
    </div>

{% endblock %}

{% block pageScripts %}
    <script src="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.js"></script>
    <script src="{{url('/assets/js/FunApp.js')}}"></script>
{% endblock %}