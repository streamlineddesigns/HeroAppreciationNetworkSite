{% extends "app.twig" %}

{% block pageStyles %}
<link rel="stylesheet" href="{{ url('/assets/css/profile.css') }}">
<style>
.profile-img {
    height: 250px;
    width: 250px;
    border-radius: 50%;
    background-image: url("{{url('/assets/img/uploads/users/')}}{{user.id}}/{{ user.profile_img_url }}");
    background-size: contain;
    box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    background-repeat: no-repeat;
    background-position: center;
    background-color: #222222;
}

.emp-profile {
    width: 550px;
    border-radius: 75px;
}
</style>
{% endblock %}


{% block title %}Profile{% endblock %}

{% block content %}

  {% if hasMessages() %}
    {% if successMessage() %}
        <script>swal("Success!", "{{successMessage()}}", "success");</script>
    {% elseif errorMessage() %}
        <script>swal("Error!", "{{errorMessage()}}", "error");</script>
    {% endif %}
  {% endif %}

  <div class="container emp-profile my-5 shadow">

  <a href="javascript:FunApp.backButtonClick()" class="btn mb-5 btn-chubby"><i class="bi bi-chevron-left"></i> Back</a>

    <form method="post" action="/user/profile" enctype="multipart/form-data">
      <div class="row">
        <div class="col-lg-12 d-flex justify-content-center align-items-center">
          <div class="profile-img">
              
              {% if user.profile_img_url %}
                <img id="profile_img_url" src="{{url('/assets/img/uploads/users/')}}{{user.id}}/{{ user.profile_img_url }}" class="hidden"  alt="profile image"/>
              {% else %}
                <img id="profile_img_url" src="{{url('/assets/img/default_profile_img.png')}}" class="hidden"  alt="default profile image"/>
              {% endif %}


              <div class="file btn btn-lg btn-primary file-custom">
                  <i class="fas fa-camera fa-2x"></i>
                  <input accept="image/*" type="file" onchange="changeImage(window.URL.createObjectURL(this.files[0]))" class="form-control form-control-file" name="profile_img_url" placeholder="profile_img_url"/>
              </div>
          </div>
        </div>
        <div class="col-lg-12 my-5">
          
          <div class="row">
              <div class="col-md-12 mt-5 mb-3">
                <ul class="nav nav-tabs" id="myTab" role="tablist">
                    <li class="nav-item" role="presentation">
                      <a class="nav-link active" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile" type="button" role="tab" aria-controls="profile" aria-selected="true">Profile</a>
                    </li>
                </ul>
              </div>
              <div class="col-md-12">
                  <div class="tab-content profile-tab" id="myTabContent">

                      <div class="tab-pane fade show active" id="profile" role="tabpanel" aria-labelledby="profile-tab">
                        <div class="row my-1">
                            <div class="col-md-6">
                                <label>First Name</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center"><input class="form-control brand-input" type="text" value="{{ user.fname }}" name="fname"></p>
                            </div>
                        </div>
                        <div class="row my-1">
                            <div class="col-md-6">
                                <label>Last Name</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center"><input class="form-control brand-input" type="text" value="{{ user.lname }}" name="lname"></p>
                            </div>
                        </div>
                        <div class="row my-1">
                            <div class="col-md-6">
                                <label>Email</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center"><input class="form-control brand-input" type="text" value="{{ user.email }}" name="email"></p>
                            </div>
                        </div>
                        
                        <div class="row mt-3">
                            <div class="col-md-6">
                                <label>Social Media</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center social-medias brand-color">
                                    {% for section_icon in section_icons %}
                                        <i class="fa-2x {{section_icon.class_name}}" value="{{section_icon.id}}"></i>
                                    {% endfor %}
                                </p>
                            </div>
                        </div>

                        <div class="row my-1">
                            <div class="col-md-6">
                                <a href id="password">Change Password</a>
                            </div>
                            <div class="col-md-6">
                                
                            </div>
                        </div>
                        <div class="row my-1" id="changepassword">
                            <hr>
                            <div class="col-md-6">
                                <label>Current Password</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center"><input class="form-control brand-input my-1" type="password" name="password" placeholder="Current Password"></p>
                            </div>

                            <div class="col-md-6">
                                <label>New Password</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center"><input class="form-control brand-input my-1" type="password" name="newpassword" placeholder="New Password"></p>
                            </div>

                            <div class="col-md-6">
                                <label>Confirm Password</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center"><input class="form-control brand-input my-1" type="password" name="confirmpassword" placeholder="Confirm Password"></p>
                            </div>
                        </div>
        
                        <div class="row mt-5">
                            <div class="col-md-12">
                                <button type="submit" class="btn btn-primary edit-btn float-right main-btn"><i class="fas fa-sd-card"></i> Save</button>
                            </div>
                        </div>

                      </div>
                  </div>
              </div>
          </div>
        </div>

    </form>           
  </div>

{% endblock %}

{% block pageScripts %}
<script src="{{url('/assets/js/FunApp.js')}}"></script>

<script>
    $(document).ready(function() {
        $("#changepassword").hide();
        $("#password").click(function() {
            event.preventDefault();
            $("#changepassword").toggle();
        });
    });

    function changeImage(img)
    {
        var source = "url('" + img +"')";
        $(".profile-img").css("background-image", source);
        console.log("testing");
    }

</script>

{% endblock %}