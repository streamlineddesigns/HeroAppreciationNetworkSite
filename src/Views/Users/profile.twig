{% extends "app.twig" %}

{% block pageStyles %}
<link rel="stylesheet" href="{{ url('/assets/css/profile.css') }}">
<style>
.profile-img {
    height: 250px;
    width: 250px;
    border-radius: 50%;
    background-image: url("{{url('/assets/img/uploads/users/')}}{{user.id}}/{{ user.profile_img_url }}");
    background-size: contain;
    box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    background-repeat: no-repeat;
    background-position: center;
    background-color: #222222;
}

.emp-profile {
    width: 550px;
    border-radius: 75px;
}
</style>
{% endblock %}

{% block title %}Profile{% endblock %}

{% block content %}

  {% if hasMessages() %}
    {% if successMessage() %}
        <script>swal("Success!", "{{successMessage()}}", "success");</script>
    {% elseif errorMessage() %}
        <script>swal("Error!", "{{errorMessage()}}", "error");</script>
    {% endif %}
  {% endif %}

  <div class="container emp-profile my-5 shadow">
    <form>
      <div class="row">
        <div class="col-md-12 mb-5">
            <a href="{{ url('/user/profile/edit') }}" class="main-btn nav-btn d-sm-inline-block float-right">Edit</a>
        </div>
        <div class="col-lg-12 d-flex justify-content-center align-items-center">
          <div class="profile-img">

              {% if user.profile_img_url %}
                <img src="{{url('/assets/img/uploads/users/')}}{{user.id}}/{{ user.profile_img_url }}" class="hidden" alt="profile image"/>
              {% else %}
                <img src="{{url('/assets/img/default_profile_img.png')}}" class="hidden" alt="default profile image"/>
              {% endif %}

          </div>
        </div>
        <div class="col-lg-12 my-5">
          <div class="row">
              
              <div class="col-md-6">
                  <div class="profile-head">
                      <h5>
                          {{ user.fname }} {{ user.lname }}
                      </h5>
                      <h6>
                          {{ user.community }}
                      </h6>
                      <p class="proile-rating"><span>Karma Points :</span> {{donations_total}}</p>
                  </div>
              </div>
          </div>
          
          <div class="row">
              <div class="col-md-12 mt-5 mb-3">
                <ul class="nav nav-tabs" id="myTab" role="tablist">
                    <li class="nav-item" role="presentation">
                      <a class="nav-link active" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile" type="button" role="tab" aria-controls="profile" aria-selected="true">Profile</a>
                    </li>
                    <li class="nav-item" role="presentation">
                      <a class="nav-link" id="donations-tab" data-bs-toggle="tab" data-bs-target="#donations" type="button" role="tab" aria-controls="donations" aria-selected="false">Donations</a>
                    </li>
                </ul>
              </div>
              <div class="col-md-12">
                  <div class="tab-content profile-tab" id="myTabContent">

                      <div class="tab-pane fade show active" id="profile" role="tabpanel" aria-labelledby="profile-tab">
                        <div class="row">
                            <div class="col-md-6">
                                <label>Name</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center">{{ user.fname }} {{ user.lname }}</p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <label>Email</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center">{{ user.email }}</p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <label>Social Media</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center social-medias brand-color">
                                  <i class="fab fa-2x fa-facebook"></i>
                                  <i class="fab fa-2x fa-instagram"></i>
                                  <i class="fab fa-2x fa-twitter"></i>
                                  <i class="fab fa-2x fa-linkedin"></i>
                                  <i class="fab fa-2x fa-google"></i>
                                </p>
                            </div>
                        </div>
                      </div>
                      <div class="tab-pane fade" id="donations" role="tabpanel" aria-labelledby="donations-tab">
                        <div class="row">
                              <div class="col-md-4">
                                  <label>To</label>
                              </div>
                              <div class="col-md-4">
                                  <label>Amount</label>
                              </div>
                              <div class="col-md-4">
                                  <label>Public</label>
                              </div>
                              
                          </div>

                          {% for donation in donations %}
                            <div class="row row_donations">
                              <div class="col-md-4">
                                  <a href="/organizations/{{donation.recipient_organization_id}}">{{donation.name}}</a>
                              </div>
                              <div class="col-md-4">
                                  <p>${{donation.amount}}</p>
                              </div>
                              <div class="col-md-4">
                                  <label>{% if donation.is_invisible == 1 %} <i class="fas fa-eye brand-color"></i> {% else %} <i class="fas fa-eye-slash"></i> {% endif %}</label>
                              </div>
                            </div>
                            <hr>
                          {% endfor %}


                      </div>
                  </div>
              </div>
          </div>
        </div>

    </form>           
  </div>

{% endblock %}