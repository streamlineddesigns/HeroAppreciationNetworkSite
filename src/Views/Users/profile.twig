{% extends "app.twig" %}

{% block pageStyles %}<link rel="stylesheet" href="{{ url('/assets/css/profile.css') }}">{% endblock %}

{% block title %}Profile{% endblock %}

{% block content %}

  {% if hasMessages() %}
    {% if successMessage() %}
        <script>swal("Success!", "{{successMessage()}}", "success");</script>
    {% elseif errorMessage() %}
        <script>swal("Error!", "{{errorMessage()}}", "error");</script>
    {% endif %}
  {% endif %}

  <div class="container emp-profile my-5">
    <form>
      <div class="row">
        <div class="col-lg-4 d-flex justify-content-center align-items-center">
          <div class="profile-img">

              {% if user.profile_img_url %}
                <img src="{{ user.profile_img_url }}" alt="profile image"/>
              {% else %}
                <img src="{{url('/assets/img/default_profile_img.png')}}" alt="default profile image"/>
              {% endif %}

              <div class="file btn btn-lg btn-primary">
                  Change Photo
                  <input type="file" name="file"/>
              </div>
          </div>
        </div>
        <div class="col-lg-8 my-5">
          <div class="row">
              <div class="col-md-6">
                  <div class="profile-head">
                      <h5>
                          {{ user.fname }} {{ user.lname }}
                      </h5>
                      <h6>
                          {{ user.community }}
                      </h6>
                      <p class="proile-rating"><span>Karma Points :</span> 750</p>
                  </div>
              </div>
              <div class="col-md-6">
                  <a href="#" class="main-btn nav-btn d-sm-inline-block float-right">Edit</a>
              </div>
          </div>
          
          <div class="row">
              <div class="col-md-12 mt-5 mb-3">
                <ul class="nav nav-tabs" id="myTab" role="tablist">
                    <li class="nav-item" role="presentation">
                      <a class="nav-link active" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile" type="button" role="tab" aria-controls="profile" aria-selected="true">Profile</a>
                    </li>
                    <li class="nav-item" role="presentation">
                      <a class="nav-link" id="donations-tab" data-bs-toggle="tab" data-bs-target="#donations" type="button" role="tab" aria-controls="donations" aria-selected="false">Donations</a>
                    </li>
                </ul>
              </div>
              <div class="col-md-12">
                  <div class="tab-content profile-tab" id="myTabContent">

                      <div class="tab-pane fade show active" id="profile" role="tabpanel" aria-labelledby="profile-tab">
                        <div class="row">
                            <div class="col-md-6">
                                <label>Name</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center">{{ user.fname }} {{ user.lname }}</p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <label>Email</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center">{{ user.email }}</p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <label>Password</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center">**********</p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <label>Social Media</label>
                            </div>
                            <div class="col-md-6">
                                <p class="text-center social-medias">
                                  <i class="fab fa-2x fa-facebook"></i>
                                  <i class="fab fa-2x fa-instagram"></i>
                                  <i class="fab fa-2x fa-twitter"></i>
                                  <i class="fab fa-2x fa-linkedin"></i>
                                  <i class="fab fa-2x fa-google"></i>
                                </p>
                            </div>
                        </div>
                      </div>
                      <div class="tab-pane fade" id="donations" role="tabpanel" aria-labelledby="donations-tab">
                        <div class="row">
                              <div class="col-md-6">
                                  <label>Date</label>
                              </div>
                              <div class="col-md-6">
                                  <label>Amount</label>
                              </div>
                          </div>
                          <div class="row">
                              <div class="col-md-6">
                                  <p>08/13/21</p>
                              </div>
                              <div class="col-md-6">
                                  <p>$100</p>
                              </div>
                          </div>
                          <div class="row">
                              <div class="col-md-6">
                                  <p>08/12/21</p>
                              </div>
                              <div class="col-md-6">
                                  <p>$100</p>
                              </div>
                          </div>
                          <div class="row">
                              <div class="col-md-6">
                                  <p>08/11/21</p>
                              </div>
                              <div class="col-md-6">
                                  <p>$100</p>
                              </div>
                          </div>
                          <div class="row">
                              <div class="col-md-6">
                                  <p>08/10/21</p>
                              </div>
                              <div class="col-md-6">
                                  <p>$100</p>
                              </div>
                          </div>

                      </div>
                  </div>
              </div>
          </div>
        </div>

    </form>           
  </div>

{% endblock %}